<?xml version="1.0" encoding="UTF-8"?>
<assembly xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2 http://maven.apache.org/xsd/assembly-1.1.2.xsd">
    <id>assembly-dir</id>
    <formats>
        <format>dir</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>

    <dependencySets>
        <dependencySet>
            <includes>
                <include>${project.groupId}:qingzhou-jdbc</include>
                <include>${project.groupId}:qingzhou-ssh</include>
                <include>${project.groupId}:qingzhou-uml</include>
                <include>${project.groupId}:qingzhou-yaml</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>lib/version/addon</outputDirectory>
        </dependencySet>

        <dependencySet>
            <includes>
                <include>${project.groupId}:Example</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>/instances/default/apps/Example</outputDirectory>
        </dependencySet>

        <dependencySet>
            <includes>
                <include>${project.groupId}:qingzhou-launcher</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>/bin</outputDirectory>
        </dependencySet>

        <dependencySet>
            <includes>
                <include>${project.groupId}:qingzhou-command</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>lib/version/command</outputDirectory>
        </dependencySet>

        <dependencySet>
            <includes>
                <include>${project.groupId}:qingzhou-engine</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>lib/version/engine</outputDirectory>
        </dependencySet>

        <dependencySet>
            <includes>
                <include>${project.groupId}:qingzhou-api</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>lib/version</outputDirectory>
        </dependencySet>

        <dependencySet>
            <includes>
                <include>${project.groupId}:qingzhou-core</include>
                <include>${project.groupId}:qingzhou-logger</include>
                <include>${project.groupId}:qingzhou-json</include>
                <include>${project.groupId}:qingzhou-serializer</include>
                <include>${project.groupId}:qingzhou-http</include>
                <include>${project.groupId}:qingzhou-qr</include>
                <include>${project.groupId}:qingzhou-crypto</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>lib/version/module</outputDirectory>
        </dependencySet>

        <dependencySet>
            <includes>
                <include>${project.groupId}:console-war</include>
            </includes>
            <unpack>true</unpack>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>lib/version/console-war</outputDirectory>
            <unpackOptions>
                <excludes>
                    <exclude>META-INF/**</exclude>
                </excludes>
            </unpackOptions>
        </dependencySet>

        <dependencySet>
            <includes>
                <include>${project.groupId}:master-app</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>lib/version/-</outputDirectory>
        </dependencySet>
    </dependencySets>
</assembly>
