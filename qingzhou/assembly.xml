<?xml version="1.0" encoding="UTF-8"?>
<assembly xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2 http://maven.apache.org/xsd/assembly-1.1.2.xsd">
    <id>assembly-dir</id>
    <formats>
        <format>dir</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>

    <fileSets>
        <fileSet>
            <directory>${project.basedir}/..</directory>
            <includes>
                <include>README.md</include>
            </includes>
            <outputDirectory>lib/version/docs</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/../docs</directory>
            <includes>
                <include>**/*.md</include>
            </includes>
            <outputDirectory>lib/version/docs</outputDirectory>
        </fileSet>
    </fileSets>

    <dependencySets>
        <dependencySet>
            <includes>
                <include>${project.groupId}:qingzhou-launcher</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>/bin</outputDirectory>
        </dependencySet>
        <dependencySet>
            <includes>
                <include>${project.groupId}:qingzhou-command</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>lib/version/command</outputDirectory>
        </dependencySet>
        <dependencySet>
            <includes>
                <include>${project.groupId}:qingzhou-engine</include>
                <include>org.apache.felix:org.apache.felix.main</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>lib/version/runtime</outputDirectory>
        </dependencySet>
        <dependencySet>
            <includes>
                <include>${project.groupId}:qingzhou-app-driver</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>lib/version/runtime/app-driver</outputDirectory>
        </dependencySet>
        <dependencySet>
            <includes>
                <include>${project.groupId}:qingzhou-bundle-converter</include>
                <include>org.javassist:javassist</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>lib/version/runtime/bundle-converter</outputDirectory>
        </dependencySet>
        <dependencySet>
            <includes>
                <include>org.apache.felix:org.apache.felix.scr</include>
                <include>org.osgi:org.osgi.service.component</include>
                <include>org.osgi:org.osgi.util.promise</include>
                <include>org.osgi:org.osgi.util.function</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>lib/version/runtime/features/scr</outputDirectory>
        </dependencySet>
        <dependencySet>
            <includes>
                <include>org.apache.felix:org.apache.felix.configadmin</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>lib/version/runtime/features/cm</outputDirectory>
        </dependencySet>
        <dependencySet>
            <includes>
                <include>org.apache.felix:org.apache.felix.log</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>lib/version/runtime/features/log</outputDirectory>
        </dependencySet>

        <dependencySet>
            <includes>
                <include>${project.groupId}:qingzhou-config</include>
                <include>${project.groupId}:qingzhou-api</include>
                <include>${project.groupId}:qingzhou-registry</include>
                <include>${project.groupId}:qingzhou-dto</include>
                <include>${project.groupId}:qingzhou-agent</include>
                <include>${project.groupId}:qingzhou-ai</include>
                <include>${project.groupId}:qingzhou-web</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>lib/version/modules</outputDirectory>
        </dependencySet>
        <dependencySet>
            <includes>
                <include>${project.groupId}:qingzhou-logger</include>
                <include>${project.groupId}:qingzhou-json</include>
                <include>${project.groupId}:qingzhou-xml</include>
                <include>${project.groupId}:qingzhou-jdbc</include>
                <include>${project.groupId}:qingzhou-detector</include>
                <include>${project.groupId}:qingzhou-qr</include>
                <include>${project.groupId}:qingzhou-crypto</include>
                <include>${project.groupId}:qingzhou-http-server</include>
                <include>${project.groupId}:qingzhou-http-client</include>
                <include>${project.groupId}:qingzhou-llm</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>lib/version/components</outputDirectory>
        </dependencySet>

        <dependencySet>
            <includes>
                <include>${project.groupId}:qingzhou-app-library</include>
                <include>${project.groupId}:qingzhou-app-demo</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputDirectory>/instances/default/apps</outputDirectory>
        </dependencySet>
    </dependencySets>
</assembly>
